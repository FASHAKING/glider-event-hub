# --------------------------------------------------------------------
# Glider Event Hub – environment variables
#
# Copy this file to `.env.local` and fill in the values from your
# Supabase project. The app will run in "demo mode" (localStorage only)
# if these variables are missing or empty.
# --------------------------------------------------------------------

# Public Supabase project URL, e.g. https://abcd1234.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public API key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=

# Optional: name of the public Storage bucket that holds event images.
# Defaults to "event-images". Create it in the Supabase dashboard.
VITE_SUPABASE_EVENT_BUCKET=event-images

# Optional: Telegram bot username (without the leading @). Used to build
# the t.me link from the "Connect Telegram" button in the profile modal.
VITE_TELEGRAM_BOT_USERNAME=
